{
  "name": "tsadwyn",
  "version": "0.1.0",
  "description": "Stripe-like API versioning framework for TypeScript/Express",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "bin": {
    "tsadwyn": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "api",
    "versioning",
    "express",
    "typescript",
    "stripe"
  ],
  "license": "MIT",
  "author": "Mahmoud Abdelkader <mabdelkader@gmail.com>",
  "homepage": "https://github.com/mahmoudimus/tsadwyn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahmoudimus/tsadwyn.git"
  },
  "bugs": {
    "url": "https://github.com/mahmoudimus/tsadwyn/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "commander": "^14.0.3",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "supertest": "^7.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
